# ---------------------------------------------------------
# A3. EXPLOIT DETECTION (SID 1000211-1000216) - CRITICAL
# ---------------------------------------------------------

# 1000211 - Shellshock exploit
drop tcp $HOME_NET any -> any any (
    msg:"EXPLOIT Shellshock CGI attack detected";
    flow:established,to_server;
    http_header;
    content:"() {";
    pcre:"/\(\)\s*\{.*;\s*\}/";
    classtype:web-application-attack;
    sid:1000211;
    rev:1;
)

# 1000212 - SQL injection attempt
drop tcp $HOME_NET any -> any any (
    msg:"EXPLOIT SQL injection attempt detected";
    flow:established,to_server;
    http_uri;
    content:"union";
    nocase;
    pcre:"/(\%27)|(\')|(\-\-)|(\%23)|(#)/i";
    classtype:web-application-attack;
    sid:1000212;
    rev:1;
)

# 1000213 - Directory traversal attack
drop tcp $HOME_NET any -> any any (
    msg:"EXPLOIT Directory traversal attempt detected";
    flow:established,to_server;
    http_uri;
    content:"../";
    pcre:"/(\.\.(\/|%2f)){2,}/i";
    classtype:web-application-attack;
    sid:1000213;
    rev:1;
)

# 1000214 - Command injection attempt
drop tcp $HOME_NET any -> any any (
    msg:"EXPLOIT Command injection attempt detected";
    flow:established,to_server;
    http_uri;
    pcre:"/(;|\||`|\$\()/";
    classtype:web-application-attack;
    sid:1000214;
    rev:1;
)

# 1000215 - XXE attack
drop tcp $HOME_NET any -> any any (
    msg:"EXPLOIT XXE attack detected";
    flow:established,to_server;
    content:"<!ENTITY";
    nocase;
    content:"SYSTEM";
    distance:0;
    within:50;
    classtype:web-application-attack;
    sid:1000215;
    rev:1;
)

# 1000216 - Log4Shell exploit (CVE-2021-44228)
drop tcp $HOME_NET any -> any any (
    msg:"EXPLOIT Log4Shell CVE-2021-44228 detected";
    flow:established;
    content:"${jndi:";
    nocase;
    pcre:"/\$\{jndi:(ldap|rmi|dns)/i";
    classtype:web-application-attack;
    sid:1000216;
    rev:1;
)

