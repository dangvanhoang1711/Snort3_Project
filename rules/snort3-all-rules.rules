# ==========================================
# Snort3 Consolidated Rules - Mini-SOC
# Combines: snort3-custom.rules + malware-detection.rules
# SID mapping must match backend-api/src/services/sid-map.js
# Snort3 syntax - tested with Snort++ 3.12.1.0
# ==========================================

# ---------------------------------------------------------
# HIGH SEVERITY - SCAN DETECTION (SID: 1000001-1000008)
# ---------------------------------------------------------

# 1000001 - SYN Scan Detected
drop tcp any any -> $HOME_NET any (
    msg:"SYN Scan Detected";
    flags:S;
    flow:stateless;
    detection_filter:track by_src, count 20, seconds 3;
    sid:1000001; rev:1;
)

# 1000002 - NULL Scan Detected
drop tcp any any -> $HOME_NET any (
    msg:"NULL Scan Detected";
    flags:0;
    flow:stateless;
    sid:1000002; rev:1;
)

# 1000003 - XMAS Scan Detected
drop tcp any any -> $HOME_NET any (
    msg:"XMAS Scan Detected";
    flags:FPU;
    flow:stateless;
    sid:1000003; rev:1;
)

# 1000004 - FIN Scan Detected
drop tcp any any -> $HOME_NET any (
    msg:"FIN Scan Detected";
    flags:F;
    flow:stateless;
    sid:1000004; rev:1;
)

# 1000005 - Stealth Scan Detected
drop tcp any any -> $HOME_NET any (
    msg:"Stealth Scan Detected";
    flags:SF;
    flow:stateless;
    sid:1000005; rev:1;
)

# 1000006 - SYN Flood Detected
drop tcp any any -> $HOME_NET any (
    msg:"SYN Flood Detected";
    flags:S;
    flow:stateless;
    detection_filter:track by_src, count 50, seconds 1;
    sid:1000006; rev:1;
)

# 1000007 - Port Scan Detected
drop tcp any any -> $HOME_NET any (
    msg:"Port Scan Detected";
    flags:S;
    flow:stateless;
    detection_filter:track by_src, count 100, seconds 10;
    sid:1000007; rev:1;
)

# 1000008 - DDoS Detected
drop tcp any any -> $HOME_NET any (
    msg:"DDoS Detected";
    flags:S;
    flow:stateless;
    detection_filter:track by_dst, count 200, seconds 5;
    sid:1000008; rev:1;
)

# ---------------------------------------------------------
# LOW SEVERITY (SID: 1000100)
# ---------------------------------------------------------

# 1000100 - ICMP Ping Allowed
pass icmp any any -> $HOME_NET any (
    msg:"ICMP Ping Allowed";
    itype:8;
    sid:1000100; rev:1;
)

# ---------------------------------------------------------
# MEDIUM SEVERITY (SID: 1000101-1000107)
# ---------------------------------------------------------

# 1000101 - ICMP Sweep Detected
drop icmp any any -> $HOME_NET any (
    msg:"ICMP Sweep Detected";
    itype:8;
    detection_filter:track by_src, count 30, seconds 5;
    sid:1000101; rev:1;
)

# 1000102 - ICMP Flood Detected
drop icmp any any -> $HOME_NET any (
    msg:"ICMP Flood Detected";
    detection_filter:track by_src, count 50, seconds 1;
    sid:1000102; rev:1;
)

# 1000103 - UDP Flood Detected
drop udp any any -> $HOME_NET any (
    msg:"UDP Flood Detected";
    detection_filter:track by_src, count 100, seconds 2;
    sid:1000103; rev:1;
)

# 1000104 - DNS Query Anomaly
alert udp any any -> $HOME_NET 53 (
    msg:"DNS Query Anomaly";
    sid:1000104; rev:1;
)

# 1000105 - ARP Spoofing Detected
alert arp any any -> $HOME_NET any (
    msg:"ARP Spoofing Detected";
    sid:1000105; rev:1;
)

# 1000106 - Ping of Death Detected
drop icmp any any -> $HOME_NET any (
    msg:"Ping of Death Detected";
    icode:0;
    itype:8;
    sid:1000106; rev:1;
)

# 1000107 - SSH Brute Force Attempt Detected
drop tcp any any -> any 22 (
    msg:"SSH Brute Force Attempt Detected";
    flags:S;
    flow:stateless;
    detection_filter:track by_src, count 5, seconds 10;
    sid:1000107; rev:1;
)

# ==========================================
# MALWARE DETECTION RULES (SID: 1000200-1000228)
# Victim VM (192.168.2.2) runs malware scripts
# Traffic direction: $HOME_NET -> any (outbound)
# ==========================================

# ---------------------------------------------------------
# A1. PAYLOAD SIGNATURES (SID: 1000200-1000205)
# ---------------------------------------------------------

# 1000200 - EICAR test file
alert tcp $HOME_NET any -> any any (
    msg:"MALWARE EICAR test file detected";
    flow:established;
    content:"X5O!P%@AP[4";
    sid:1000200; rev:1;
)

# 1000201 - Metasploit payload pattern
alert tcp $HOME_NET any -> any any (
    msg:"MALWARE Metasploit payload pattern";
    flow:established;
    content:"|fc e8 82 00 00 00|";
    sid:1000201; rev:1;
)

# 1000202 - Reverse shell command
alert tcp $HOME_NET any -> any any (
    msg:"MALWARE Reverse shell command detected";
    flow:established;
    content:"/bin/bash -i";
    sid:1000202; rev:1;
)

# 1000203 - Netcat backdoor
alert tcp $HOME_NET any -> any any (
    msg:"MALWARE Netcat backdoor pattern";
    flow:established;
    content:"nc -e /bin";
    sid:1000203; rev:1;
)

# 1000204 - Python reverse shell
alert tcp $HOME_NET any -> any any (
    msg:"MALWARE Python reverse shell detected";
    flow:established;
    content:"import socket";
    content:"connect";
    sid:1000204; rev:1;
)

# 1000205 - Encoded PowerShell payload
alert tcp $HOME_NET any -> any any (
    msg:"MALWARE Encoded PowerShell payload";
    flow:established;
    content:"powershell -enc";
    sid:1000205; rev:1;
)

# ---------------------------------------------------------
# A2. C2 COMMUNICATION (SID: 1000206-1000210)
# Matches traffic from system-update.sh on Victim
# Target: 192.168.1.2:8080 (Kali C2 server)
# ---------------------------------------------------------

# 1000206 - Cobalt Strike beacon pattern
drop tcp $HOME_NET any -> any 8080 (
    msg:"MALWARE Cobalt Strike beacon pattern detected";
    flow:established, to_server;
    http_header;
    content:"User-Agent: Mozilla/5.0 (compatible; MSIE";
    http_uri;
    content:"/submit.php";
    sid:1000206; rev:1;
)

# 1000207 - Suspicious bot User-Agent
drop tcp $HOME_NET any -> any 8080 (
    msg:"MALWARE Suspicious bot User-Agent detected";
    flow:established, to_server;
    http_header;
    content:"User-Agent: BotClient";
    sid:1000207; rev:1;
)

# 1000208 - C2 check-in URI pattern
drop tcp $HOME_NET any -> any 8080 (
    msg:"MALWARE C2 check-in URI pattern detected";
    flow:established, to_server;
    http_uri;
    content:"/api/check";
    sid:1000208; rev:1;
)

# 1000209 - C2 registration URI
drop tcp $HOME_NET any -> any 8080 (
    msg:"MALWARE C2 registration attempt detected";
    flow:established, to_server;
    http_uri;
    content:"/api/register";
    sid:1000209; rev:1;
)

# 1000210 - Suspicious POST to root
drop tcp $HOME_NET any -> any 8080 (
    msg:"MALWARE Suspicious POST to root path detected";
    flow:established, to_server;
    content:"POST / HTTP";
    depth:12;
    sid:1000210; rev:1;
)

# ---------------------------------------------------------
# A3. EXPLOIT DETECTION (SID: 1000211-1000216)
# ---------------------------------------------------------

# 1000211 - Shellshock exploit
alert tcp $HOME_NET any -> any 80 (
    msg:"EXPLOIT Shellshock CGI attack";
    flow:established, to_server;
    http_header;
    content:"() {";
    sid:1000211; rev:1;
)

# 1000212 - SQL injection attempt
alert tcp $HOME_NET any -> any 80 (
    msg:"EXPLOIT SQL injection attempt";
    flow:established, to_server;
    http_uri;
    content:"union select";
    sid:1000212; rev:1;
)

# 1000213 - Directory traversal
alert tcp $HOME_NET any -> any 80 (
    msg:"EXPLOIT Directory traversal attempt";
    flow:established, to_server;
    http_uri;
    content:"../../../";
    sid:1000213; rev:1;
)

# 1000214 - Command injection
alert tcp $HOME_NET any -> any 80 (
    msg:"EXPLOIT Command injection attempt";
    flow:established, to_server;
    http_uri;
    content:";/bin/sh";
    sid:1000214; rev:1;
)

# 1000215 - XXE attack
alert tcp $HOME_NET any -> any any (
    msg:"EXPLOIT XXE attack detected";
    flow:established, to_server;
    content:"<!ENTITY";
    content:"SYSTEM";
    sid:1000215; rev:1;
)

# 1000216 - Log4Shell exploit
alert tcp $HOME_NET any -> any any (
    msg:"EXPLOIT Log4Shell CVE-2021-44228";
    flow:established;
    content:"${jndi:ldap";
    sid:1000216; rev:1;
)

# ---------------------------------------------------------
# A4. RANSOMWARE INDICATORS (SID: 1000217-1000219)
# ---------------------------------------------------------

# 1000217 - Ransomware note keywords
alert tcp $HOME_NET any -> any any (
    msg:"RANSOMWARE Ransom note detected";
    flow:established;
    content:"Your files have been encrypted";
    sid:1000217; rev:1;
)

# 1000218 - Ransomware file extension pattern
alert tcp $HOME_NET any -> any any (
    msg:"RANSOMWARE Encrypted file extension";
    flow:established;
    content:".locked";
    sid:1000218; rev:1;
)

# 1000219 - Ransomware payment instruction
alert tcp $HOME_NET any -> any any (
    msg:"RANSOMWARE Payment instruction detected";
    flow:established;
    content:"bitcoin";
    content:"wallet";
    sid:1000219; rev:1;
)

# ---------------------------------------------------------
# A5. DATA EXFILTRATION (SID: 1000220-1000221)
# ---------------------------------------------------------

# 1000220 - Base64 encoded data exfil
alert tcp $HOME_NET any -> any any (
    msg:"EXFIL Base64 encoded data transfer";
    flow:established, to_server;
    http_uri;
    content:"data=";
    sid:1000220; rev:1;
)

# 1000221 - Sensitive data keywords
alert tcp $HOME_NET any -> any any (
    msg:"EXFIL Sensitive data in cleartext";
    flow:established;
    content:"password=";
    sid:1000221; rev:1;
)

# ---------------------------------------------------------
# B1. FLOWBITS MULTI-STAGE C2 (SID: 1000222-1000224)
# Matches system-update.sh multi-stage C2 behavior
# ---------------------------------------------------------

# 1000222 - C2 registration stage 1 (set flowbit, generate alert)
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE C2 beacon registration detected";
    flow:established, to_server;
    http_uri;
    content:"/api/register";
    http_header;
    content:"User-Agent: BotClient";
    flowbits:set,c2_registered;
    classtype:trojan-activity;
    sid:1000222; rev:1;
)

# 1000223 - C2 active beacon stage 2 (alert only if registered)
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE C2 active beacon after registration";
    flow:established, to_server;
    flowbits:isset,c2_registered;
    http_uri;
    content:"/api/check";
    classtype:trojan-activity;
    sid:1000223; rev:1;
)

# 1000224 - C2 command execution stage 3
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE C2 command execution detected";
    flow:established, to_server;
    flowbits:isset,c2_registered;
    http_uri;
    content:"/api/exec";
    classtype:trojan-activity;
    sid:1000224; rev:1;
)

# ---------------------------------------------------------
# B2. THRESHOLD / RATE-BASED (SID: 1000225-1000226)
# ---------------------------------------------------------

# 1000225 - DNS tunneling high query rate
# Matches network-diagnostic.sh high-rate DNS queries
alert udp $HOME_NET any -> any 53 (
    msg:"MALWARE DNS tunneling high query rate";
    dsize:>100;
    detection_filter:track by_src, count 10, seconds 30;
    sid:1000225; rev:1;
)

# 1000226 - Periodic C2 beacon timing
# Matches system-update.sh heartbeat pattern
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE Periodic C2 beacon pattern detected";
    flow:established, to_server;
    http_uri;
    content:"/heartbeat";
    classtype:trojan-activity;
    detection_filter:track by_src, count 3, seconds 60;
    sid:1000226; rev:1;
)

# ---------------------------------------------------------
# B3. PROTOCOL ANOMALY (SID: 1000227)
# ---------------------------------------------------------

# 1000227 - DNS query excessive length
# Matches network-diagnostic.sh oversized DNS queries
alert udp $HOME_NET any -> any 53 (
    msg:"MALWARE DNS query excessive length";
    dsize:>150;
    sid:1000227; rev:1;
)

# ---------------------------------------------------------
# B4. FILE INSPECTOR (SID: 1000228)
# ---------------------------------------------------------

# 1000228 - PE executable downloaded
alert tcp $HOME_NET any -> any any (
    msg:"MALWARE PE executable downloaded";
    flow:established, to_client;
    file_data;
    content:"|4d 5a|";
    sid:1000228; rev:1;
)

# ==========================================
# END OF RULES
# ==========================================
