# ---------------------------------------------------------
# HIGH SEVERITY SCANS (SID: 1000001-1000007)
# ---------------------------------------------------------

# 1000001 - SYN Scan Detected
drop tcp any any -> 192.168.2.0/24 any (
    msg:"SYN Scan Detected";
    flags:S;
    flow:stateless;
    detection_filter:track by_src,count 20,seconds 3;
    sid:1000001;
    rev:1;
)

# 1000002 - NULL Scan Detected
drop tcp any any -> 192.168.2.0/24 any (
    msg:"NULL Scan Detected";
    flags:0;
    flow:stateless;
    sid:1000002;
    rev:1;
)

