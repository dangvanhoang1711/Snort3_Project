# ---------------------------------------------------------
# A5. DATA EXFILTRATION (SID 1000220-1000221) - HIGH
# Matches network-diagnostic.sh HTTP exfiltration
# ---------------------------------------------------------

# 1000220 - Base64 encoded data exfiltration (network-diagnostic.sh)
drop tcp $HOME_NET any -> any any (
    msg:"EXFIL Base64 encoded data transfer detected";
    flow:established,to_server;
    content:"data=";
    pcre:"/data=[A-Za-z0-9+\/\-_]{50,}/";
    classtype:policy-violation;
    sid:1000220;
    rev:1;
)

# 1000221 - Sensitive data in cleartext
drop tcp $HOME_NET any -> any any (
    msg:"EXFIL Sensitive data in cleartext detected";
    flow:established;
    content:"password";
    nocase;
    content:"username";
    nocase;
    distance:0;
    within:100;
    classtype:policy-violation;
    sid:1000221;
    rev:1;
)

# ---------------------------------------------------------
# B1. FLOWBITS MULTI-STAGE (SID 1000222-1000224) - HIGH
# Matches system-update.sh multi-stage C2 behavior
# ---------------------------------------------------------

# 1000222 - C2 registration (stage 1, no alert)
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE C2 beacon registration";
    flow:established,to_server;
    http_uri;
    content:"/api/register";
    http_header;
    content:"User-Agent: BotClient";
    flowbits:set,c2_registered;
    flowbits:noalert;
    classtype:trojan-activity;
    sid:1000222;
    rev:1;
)

# 1000223 - C2 active beacon (stage 2, alert if registered)
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE C2 active beacon after registration";
    flow:established,to_server;
    flowbits:isset,c2_registered;
    http_uri;
    content:"/api/check";
    classtype:trojan-activity;
    sid:1000223;
    rev:1;
)

# 1000224 - C2 command execution (stage 3, system-update.sh /api/exec)
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE C2 command execution detected";
    flow:established,to_server;
    flowbits:isset,c2_registered;
    http_uri;
    content:"/api/exec";
    classtype:trojan-activity;
    sid:1000224;
    rev:1;
)

# ---------------------------------------------------------
# B2. DETECTION FILTER RATE-BASED (SID 1000225-1000226) - MEDIUM
# Matches network-diagnostic.sh DNS tunneling
# ---------------------------------------------------------

# 1000225 - DNS tunneling by volume (network-diagnostic.sh high-rate)
drop udp $HOME_NET any -> any 53 (
    msg:"MALWARE DNS tunneling high query rate detected";
    dsize:>150;
    detection_filter:track by_src,count 10,seconds 30;
    classtype:policy-violation;
    sid:1000225;
    rev:1;
)

# 1000226 - Periodic C2 beacon timing (system-update.sh heartbeat)
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE Periodic C2 beacon pattern detected";
    flow:established,to_server;
    http_uri;
    content:"/heartbeat";
    detection_filter:track by_src,count 5,seconds 60;
    classtype:trojan-activity;
    sid:1000226;
    rev:1;
)

# ---------------------------------------------------------
# B4. PROTOCOL ANOMALY (SID 1000227) - MEDIUM
# Matches network-diagnostic.sh oversized DNS queries
# ---------------------------------------------------------

# 1000227 - Oversized DNS query (network-diagnostic.sh tunneling)
drop udp $HOME_NET any -> any 53 (
    msg:"MALWARE DNS query excessive length detected";
    dsize:>200;
    content:"|01 00 00 01|";
    offset:2;
    depth:4;
    classtype:policy-violation;
    sid:1000227;
    rev:1;
)

# ---------------------------------------------------------
# B3. FILE INSPECTOR (SID 1000228) - HIGH
# ---------------------------------------------------------

# 1000228 - PE executable download
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE PE executable downloaded";
    flow:established,to_client;
    file_data;
    content:"|4d 5a|";
    depth:2;
    content:"PE|00 00|";
    distance:58;
    within:4;
    classtype:trojan-activity;
    sid:1000228;
    rev:1;
)

