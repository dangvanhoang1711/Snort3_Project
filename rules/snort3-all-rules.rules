# ==========================================
# SECTION 2: MALWARE DETECTION
# SID Range: 1000200-1000228 (29 rules)
# Direction: Victim ($HOME_NET) outbound to external
# Matches stealth malware scripts:
#   - system-update.sh (C2 beacon/command execution)
#   - network-diagnostic.sh (DNS tunneling/exfiltration)
# ==========================================

# ---------------------------------------------------------
# A1. PAYLOAD SIGNATURES (SID 1000200-1000205) - HIGH
# ---------------------------------------------------------

# 1000200 - EICAR test file signature
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE EICAR test file detected";
    flow:established;
    content:"X5O!P%@AP[4|5c|PZX54(P^)7CC)7}$EICAR-STANDARD-ANTIVIRUS-TEST-FILE!$H+H*";
    classtype:trojan-activity;
    sid:1000200;
    rev:1;
)

# 1000201 - Metasploit payload pattern
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE Metasploit payload pattern detected";
    flow:established;
    content:"|fc e8 82 00 00 00|";
    depth:6;
    classtype:trojan-activity;
    sid:1000201;
    rev:1;
)

# 1000202 - Reverse shell command pattern
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE Reverse shell command detected";
    flow:established;
    content:"/bin/bash";
    nocase;
    content:"-i";
    distance:0;
    within:20;
    classtype:trojan-activity;
    sid:1000202;
    rev:1;
)

# 1000203 - Netcat backdoor pattern
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE Netcat backdoor pattern detected";
    flow:established;
    content:"nc";
    nocase;
    content:"-e";
    distance:0;
    within:10;
    pcre:"/nc\s+-[el]/i";
    classtype:trojan-activity;
    sid:1000203;
    rev:1;
)

# 1000204 - Python reverse shell
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE Python reverse shell detected";
    flow:established;
    content:"python";
    nocase;
    content:"socket";
    distance:0;
    within:100;
    content:"connect";
    distance:0;
    within:100;
    classtype:trojan-activity;
    sid:1000204;
    rev:1;
)

# 1000205 - Encoded PowerShell payload
drop tcp $HOME_NET any -> any any (
    msg:"MALWARE Encoded PowerShell payload detected";
    flow:established;
    content:"powershell";
    nocase;
    content:"-enc";
    distance:0;
    within:20;
    classtype:trojan-activity;
    sid:1000205;
    rev:1;
)

